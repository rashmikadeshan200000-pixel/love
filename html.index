<!DOCTYPE html>
<html lang="si">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>For My Dear Amasha ❤️</title>
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: #ffdef2;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            overflow: hidden;
            text-align: center;
        }

        /* Login Box Styling */
        #login-box {
            background: white;
            padding: 40px;
            border-radius: 30px;
            box-shadow: 0 15px 35px rgba(255, 77, 109, 0.2);
            z-index: 100;
        }

        input {
            padding: 12px;
            width: 80%;
            border: 2px solid #ff4d6d;
            border-radius: 15px;
            margin-bottom: 15px;
            font-size: 16px;
            outline: none;
            text-align: center;
        }

        button {
            padding: 12px 25px;
            background: #ff4d6d;
            color: white;
            border: none;
            border-radius: 15px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover { transform: scale(1.1); background: #ff758f; }

        /* Main Gift Content */
        #main-content {
            display: none;
            width: 100%;
        }

        .photo-container {
            width: 300px;
            height: 350px;
            margin: 0 auto;
            border: 8px solid white;
            border-radius: 20px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            overflow: hidden;
            background: #eee;
        }

        .photo-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: none;
        }

        .photo-container img.active { display: block; animation: zoomIn 1s ease-out; }

        @keyframes zoomIn {
            from { transform: scale(0.8); opacity: 0; }
            to { transform: scale(1); opacity: 1; }
        }

        /* Hearts Animation */
        .heart {
            position: absolute;
            color: #ff4d6d;
            animation: moveUp 4s linear forwards;
            top: 100%;
            pointer-events: none;
        }

        @keyframes moveUp {
            to { transform: translateY(-110vh) rotate(360deg); opacity: 0; }
        }

        h1 { color: #ff4d6d; margin-top: 20px; font-size: 2rem; }
        p { color: #555; font-size: 1.1rem; padding: 0 20px; }
    </style>
</head>
<body>

    <div id="login-box">
        <h2 style="color: #ff4d6d;">Enter Secret Code 🔑</h2>
        <input type="password" id="pass" placeholder="ඔයාගෙ නම මෙතන ගහන්න...">
        <br>
        <button onclick="unlock()">Unlock My Love</button>
        <p id="msg" style="color: red; display: none; margin-top: 10px; font-size: 14px;">වැරදියි! ඔයාගෙ නම නිවැරදිව (Amasha) ලෙස ඇතුළත් කරන්න 🥺</p>
    </div>

    <div id="main-content">
        <div class="photo-container">
            <img src="img1.jpg" class="active">
            <img src="img2.jpg">
            <img src="img3.jpg">
        </div>
        <h1>I Love You, Amasha! ❤️</h1>
        <p>ඔයා මගේ ජීවිතේට ලැබුණු වටිනාම තෑග්ග!</p>
    </div>

    <script>
        function unlock() {
            const code = document.getElementById('pass').value;
            
            // රහස් කේතය මෙන්න (Amasha)
            if (code === "Amasha") {
                document.getElementById('login-box').style.display = 'none';
                document.getElementById('main-content').style.display = 'block';
                startHearts();
                startSlideshow();
            } else {
                document.getElementById('msg').style.display = 'block';
            }
        }

        // Slideshow: පින්තූර මාරු වීමට
        let currentImg = 0;
        function startSlideshow() {
            const imgs = document.querySelectorAll('.photo-container img');
            if (imgs.length > 1) {
                setInterval(() => {
                    imgs[currentImg].classList.remove('active');
                    currentImg = (currentImg + 1) % imgs.length;
                    imgs[currentImg].classList.add('active');
                }, 3000); 
            }
        }

        // Floating Hearts: හදවත් පාවීමට
        function startHearts() {
            setInterval(() => {
                const heart = document.createElement('div');
                heart.innerHTML = '❤️';
                heart.className = 'heart';
                heart.style.left = Math.random() * 100 + 'vw';
                heart.style.fontSize = (Math.random() * 20 + 15) + 'px';
                heart.style.animationDuration = (Math.random() * 2 + 3) + 's';
                document.body.appendChild(heart);
                setTimeout(() => heart.remove(), 4000);
            }, 300);
        }
    </script>
</body>
</html>
